# ─── Payload CMS ───────────────────────────────────────────
PAYLOAD_SECRET=your-long-random-secret-string-here

# ─── Database (Supabase PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Square API ────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_APP_ID=your-square-app-id
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key
# Exact notification URL Square is configured to call (used to verify HMAC).
# In dev with ngrok this is the tunnel URL; in prod the public webhook URL.
SQUARE_WEBHOOK_URL=https://www.delicatessenbyjanis.com/api/square/webhook

# ─── Cloudflare R2 (Media Storage) ─────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=delicatessen-media
R2_PUBLIC_URL=https://media.delicatessenbyjanis.com

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=orders@delicatessenbyjanis.com
EMAIL_ADMIN=janis@delicatessenbyjanis.com

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SQUARE_APP_ID=your-square-app-id
# Mirror of SQUARE_LOCATION_ID exposed to the browser so the Web Payments
# SDK can initialize. The location IDs are not secret.
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-square-location-id
# "sandbox" or "production" — controls which Square Web Payments CDN script
# the checkout page loads. Should match SQUARE_ENVIRONMENT.
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
